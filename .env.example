GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# GCS bucket used only during deployment (notebook/deploy.py).
# Create once: gsutil mb -l us-central1 gs://your-project-id-agent-staging
STAGING_BUCKET=gs://your-project-id-agent-staging

# Resource name of your deployed agent — copy from notebook Section 10 output.
# Example: projects/my-project/locations/us-central1/reasoningEngines/1234567890
AGENT_ENGINE_RESOURCE_NAME=
